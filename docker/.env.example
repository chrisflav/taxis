# Copy this file to .env (same directory) and fill in the values you need, then run
# `docker compose up --build` from the docker/ directory — Compose loads docker/.env
# automatically, no extra flags needed. .env itself is gitignored — never commit real
# secrets from it.

# Host port to publish the server on (container always listens on 8080 internally).
HOST_PORT=8080

# Host directory holding the SQLite database, bind-mounted at /data in the container. Relative
# paths are resolved against docker/ (where docker-compose.yaml lives).
TAXIS_DATA_DIR=./data

# Public URL the server is reached at — required for the Google/GitHub OAuth redirect URIs to be
# correct, and used to build absolute links. If you override HOST_PORT (or put this behind a
# different host/port entirely, e.g. a reverse proxy), override this to match.
ISSUES_BASE_URL=http://localhost:8080

# Comma-separated emails granted admin on first login.
ISSUES_ADMIN_EMAILS=

# Set to enable single-password sign-in instead of/alongside Google/GitHub OAuth.
ISSUES_CENTRAL_PASSWORD=

# Google OAuth (leave unset to run in open/local mode — see the README).
ISSUES_GOOGLE_CLIENT_ID=
ISSUES_GOOGLE_CLIENT_SECRET=

# GitHub OAuth App, for "Sign in with GitHub" (leave unset to disable). Distinct from
# ISSUES_GITHUB_TOKEN below — see the README's Configuration section.
ISSUES_GITHUB_CLIENT_ID=
ISSUES_GITHUB_CLIENT_SECRET=

# Token for GitHub API calls (import, github-ci checks).
ISSUES_GITHUB_TOKEN=

# Background check-sweep interval in seconds; 0 disables it.
ISSUES_CHECK_INTERVAL=0

# Set (to any value) to enable POST /api/auth/dev-login. Do not set this in production.
ISSUES_DEV_LOGIN=
